<!DOCTYPE html>
<html>
<head>
    <title>Review Risk Analyzer</title>
    <style>
        body { font-family: sans-serif; display: flex; justify-content: center; padding: 50px; }
        .container { border: 1px solid #ccc; padding: 20px; border-radius: 10px; width: 400px; }
        textarea { width: 100%; height: 100px; margin-bottom: 10px; }
        button { width: 100%; padding: 10px; background: #007bff; color: white; border: none; cursor: pointer; }
        #results { margin-top: 20px; display: none; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Review Analyzer</h2>
        <textarea id="textInput" placeholder="Type review..."></textarea>
        <button onclick="analyze()">Analyze</button>
        <div id="results">
            <p>Sentiment: <b id="sentiment"></b></p>
            <p>Risk: <b id="risk"></b></p>
        </div>
    </div>

    <script>
        async function analyze() {
            const text = document.getElementById('textInput').value;
            const response = await fetch('/predict', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({text: text})
            });
            const data = await response.json();
            document.getElementById('results').style.display = 'block';
            document.getElementById('sentiment').innerText = data.sentiment;
            document.getElementById('risk').innerText = data.risk_tier;
        }
    </script>
</body>
</html>